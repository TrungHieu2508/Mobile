<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundCream"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header Curved Gradient Background -->
        <View
            android:id="@+id/headerBg"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_profile_gradient_header"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Header Subtitle -->
        <TextView
            android:id="@+id/txtHeaderSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/profile_title"
            android:textColor="#E0E6ED"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Top Info Overview Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardUserInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/txtHeaderSubtitle">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- Avatar border circle -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/outerAvatarCard"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    app:cardCornerRadius="42dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/profileAvatarBorder"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <!-- Inner Avatar Content -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/primaryGreenLightest">

                        <ImageView
                            android:id="@+id/imgAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_profile"
                            android:padding="16dp"
                            app:tint="@color/primaryGreen"
                            android:contentDescription="@null" />
                    </androidx.cardview.widget.CardView>
                </androidx.cardview.widget.CardView>

                <!-- Active status dot -->
                <View
                    android:id="@+id/viewStatusDot"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="@drawable/bg_status_dot"
                    android:layout_marginBottom="2dp"
                    android:layout_marginEnd="2dp"
                    app:layout_constraintBottom_toBottomOf="@id/outerAvatarCard"
                    app:layout_constraintEnd_toEndOf="@id/outerAvatarCard" />

                <!-- Status Pill (Hoạt động) -->
                <TextView
                    android:id="@+id/txtStatusPill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_badge_active"
                    android:text="@string/active_status"
                    android:textColor="@color/profileStatusText"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/outerAvatarCard"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- User Name Display -->
                <TextView
                    android:id="@+id/txtProfileName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/not_updated"
                    android:textColor="#2A3B4E"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/outerAvatarCard"
                    app:layout_constraintTop_toBottomOf="@id/txtStatusPill" />

                <!-- Role display line -->
                <ImageView
                    android:id="@+id/imgRoleIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/grayMedium"
                    android:contentDescription="@null"
                    app:layout_constraintStart_toEndOf="@id/outerAvatarCard"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileName" />

                <TextView
                    android:id="@+id/txtProfileRoleBadge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/customer_role"
                    android:textColor="@color/grayMedium"
                    android:textSize="13sp"
                    app:layout_constraintBottom_toBottomOf="@id/imgRoleIcon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/imgRoleIcon"
                    app:layout_constraintTop_toTopOf="@id/imgRoleIcon" />

                <!-- Info detail/email display line -->
                <ImageView
                    android:id="@+id/imgEmailIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="6dp"
                    android:src="@drawable/ic_email"
                    app:tint="@color/grayMedium"
                    android:contentDescription="@null"
                    app:layout_constraintStart_toEndOf="@id/outerAvatarCard"
                    app:layout_constraintTop_toBottomOf="@id/imgRoleIcon" />

                <TextView
                    android:id="@+id/txtProfileEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/default_email"
                    android:textColor="@color/grayMedium"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    app:layout_constraintBottom_toBottomOf="@id/imgEmailIcon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/imgEmailIcon"
                    app:layout_constraintTop_toTopOf="@id/imgEmailIcon" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bottom Update Info Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardUpdateInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/cardUserInfo">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/update_info"
                    android:textColor="#2A3B4E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Name Input Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_profile_input"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        app:tint="@color/grayMedium"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/edtProfileName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="@string/name_hint"
                        android:textColor="@color/grayDark"
                        android:textSize="14sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textPersonName"
                        android:autofillHints="name" />
                </LinearLayout>

                <!-- Phone Input Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_profile_input"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_phone"
                        app:tint="@color/grayMedium"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/edtProfilePhone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="@string/phone_hint"
                        android:textColor="@color/grayDark"
                        android:textSize="14sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="phone"
                        android:autofillHints="phone" />
                </LinearLayout>

                <!-- Email Display (Read-Only Input Box style) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_profile_input"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal"
                    android:alpha="0.8">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_email"
                        app:tint="@color/grayMedium"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/edtProfileEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="@string/email_address_hint"
                        android:textColor="@color/grayMedium"
                        android:textSize="14sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textEmailAddress"
                        android:enabled="false"
                        android:autofillHints="emailAddress" />
                </LinearLayout>

                <!-- Save Action Button -->
                <Button
                    android:id="@+id/btnConfirmUpdate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/profileButtonColor"
                    android:text="@string/confirm_update"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_check"
                    app:iconTint="@color/white"
                    app:iconSize="18dp"
                    app:iconPadding="8dp"
                    app:iconGravity="textStart"
                    app:cornerRadius="26dp"
                    android:layout_marginBottom="12dp" />

                <!-- Change Password Secondary Button -->
                <Button
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/grayLight"
                    android:text="@string/change_password"
                    android:textColor="@color/grayDark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_lock"
                    app:iconTint="@color/grayDark"
                    app:iconSize="18dp"
                    app:iconPadding="8dp"
                    app:iconGravity="textStart"
                    app:cornerRadius="26dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Secondary Section Scroll Stack (Role Panels, Promos, Logout) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/cardUpdateInfo"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Admin / Staff Shortcuts Layout -->
            <LinearLayout
                android:id="@+id/layoutRoleShortcuts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnOpenAdminPanel"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="10dp"
                    android:backgroundTint="@color/primaryBrown"
                    android:text="@string/admin_page"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:cornerRadius="26dp"
                    app:icon="@drawable/ic_home"
                    app:iconSize="18dp"
                    app:iconTint="@color/white"
                    app:iconPadding="8dp" />

                <Button
                    android:id="@+id/btnOpenStaffPanel"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="10dp"
                    android:backgroundTint="@color/primaryGreen"
                    android:text="@string/staff_page"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:cornerRadius="26dp"
                    app:icon="@drawable/ic_home"
                    app:iconSize="18dp"
                    app:iconTint="@color/white"
                    app:iconPadding="8dp" />

            </LinearLayout>

            <!-- Customer Promo Vouchers -->
            <LinearLayout
                android:id="@+id/layoutProfilePromos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/promo_gift_title"
                    android:textColor="@color/primaryBrown"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCustomerPromos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            </LinearLayout>

            <!-- Logout Button -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/redLight"
                android:text="@string/logout"
                android:textColor="@color/redAccent"
                android:textStyle="bold"
                app:cornerRadius="26dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
