<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Order Type, Checkbox and Status Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/chkOrderSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:buttonTint="@color/primaryGreen"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtOrderHeaderType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Giao tận nhà"
                android:textColor="@color/primaryGreen"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOrderStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_role"
                android:backgroundTint="@color/primaryGreenLightest"
                android:text="ĐANG CHUẨN BỊ"
                android:textColor="@color/primaryGreen"
                android:textSize="11sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btnDeleteOrder"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/redLight"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_delete"
                    app:tint="@color/redAccent" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Time & Order ID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtOrderTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="21/06/2026 14:30"
                android:textColor="@color/grayMedium"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã: #MV89A2"
                android:textColor="@color/grayMedium"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@color/grayLight" />

        <!-- Address or Table Detail -->
        <TextView
            android:id="@+id/txtOrderDestination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Địa chỉ: 123 Đường Nguyễn Trãi, Quận 1"
            android:textColor="@color/grayDark"
            android:textSize="13sp" />

        <!-- Items Summary List -->
        <TextView
            android:id="@+id/txtOrderItemsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="1x Matcha Latte (Size M, 50% Đường, 100% Đá)\n2x Cafe Đen Đá (Size L)"
            android:textColor="@color/grayDark"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@color/grayLight" />

        <!-- Footer: Total Pay and Payment status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtOrderPaymentStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Đã thanh toán (Mã QR)"
                android:textColor="@color/greenAccent"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOrderTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="135.000 đ"
                android:textColor="@color/primaryBrown"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dynamic Action buttons for Staff / Admin if applicable -->
        <LinearLayout
            android:id="@+id/layoutOrderActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOrderActionCancel"
                style="@style/Widget.Material3.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="Hủy đơn"
                android:textColor="@color/white"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@color/redAccent"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOrderActionNext"
                style="@style/Widget.Material3.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1.5"
                android:text="Duyệt đơn"
                android:textColor="@color/primaryGreen"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@color/white"
                app:strokeColor="@color/primaryGreen"
                app:strokeWidth="1dp"
                app:cornerRadius="20dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
