<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Squared rounded image -->
        <androidx.cardview.widget.CardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgCartItem"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/app_logo" />
        </androidx.cardview.widget.CardView>

        <!-- Product details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtCartItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Matcha Latte"
                android:textColor="@color/primaryGreen"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCartItemOptions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Size: M | Đường: 100% | Đá: 100%"
                android:textColor="@color/grayMedium"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/txtCartItemNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Ghi chú: Không có"
                android:textColor="@color/grayMedium"
                android:textSize="11sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/txtCartItemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="45.000 đ"
                android:textColor="@color/redAccent"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Quantity Selector below details -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnCartQtyMinus"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_badge_role"
                    android:backgroundTint="@color/grayLight"
                    android:text="-"
                    android:textColor="@color/primaryBrown"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/txtCartQtyCount"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/primaryBrown"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnCartQtyPlus"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_badge_role"
                    android:backgroundTint="@color/grayLight"
                    android:text="+"
                    android:textColor="@color/primaryBrown"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>

        <!-- Right Side: Delete / trash icon + Total price for this item -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:layout_marginStart="8dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnRemoveCartItem"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@drawable/ic_delete"
                app:tint="@color/redAccent" />

            <TextView
                android:id="@+id/txtCartItemTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="45.000 đ"
                android:textColor="@color/redAccent"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
