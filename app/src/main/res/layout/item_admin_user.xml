<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtAdminUserName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Nguyễn Văn A"
                android:textColor="@color/primaryGreen"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAdminUserRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_role"
                android:text="STAFF"
                android:textColor="@color/primaryGreenDark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btnDeleteUser"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/redLight"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_delete"
                    app:tint="@color/redAccent" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView
            android:id="@+id/txtAdminUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Email: staff@gmail.com"
            android:textColor="@color/grayDark"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtAdminUserPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="SĐT: 0987654321"
            android:textColor="@color/grayDark"
            android:textSize="12sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@color/grayLight" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cấp quyền tài khoản:"
            android:textColor="@color/grayMedium"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMakeCustomer"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Khách"
                android:textColor="#555555"
                android:textSize="9sp"
                android:textStyle="bold"
                android:backgroundTint="#F5F5F5"
                app:icon="@drawable/ic_person"
                app:iconTint="#555555"
                app:iconSize="10dp"
                app:iconPadding="4dp"
                app:strokeColor="#DDE3EA"
                app:strokeWidth="1dp"
                app:cornerRadius="19dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMakeStaff"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1.2"
                android:layout_marginHorizontal="3dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Nhân viên"
                android:textColor="@color/primaryGreenDark"
                android:textSize="9sp"
                android:textStyle="bold"
                android:backgroundTint="#E8F3D6"
                app:icon="@drawable/ic_badge"
                app:iconTint="@color/primaryGreenDark"
                app:iconSize="10dp"
                app:iconPadding="4dp"
                app:strokeColor="@color/primaryGreenLight"
                app:strokeWidth="1dp"
                app:cornerRadius="19dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMakeAdmin"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Admin"
                android:textColor="@color/primaryBrownDark"
                android:textSize="9sp"
                android:textStyle="bold"
                android:backgroundTint="#FDF0E2"
                app:icon="@drawable/ic_crown"
                app:iconTint="@color/primaryBrownDark"
                app:iconSize="9dp"
                app:iconPadding="4dp"
                app:strokeColor="@color/accentColor"
                app:strokeWidth="1dp"
                app:cornerRadius="19dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
