<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:gravity="center_horizontal|bottom"
    android:orientation="vertical"
    android:paddingHorizontal="4dp">

    <!-- Amount value above the bar -->
    <TextView
        android:id="@+id/txtChartBarValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0k"
        android:textColor="@color/primaryBrown"
        android:textSize="9sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- The actual vertical bar -->
    <View
        android:id="@+id/viewChartBarVisual"
        android:layout_width="18dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_chart_bar" />

    <!-- Date/Month/Year label below the bar -->
    <TextView
        android:id="@+id/txtChartBarLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="22/06"
        android:textColor="@color/grayDark"
        android:textSize="9sp" />
</LinearLayout>
